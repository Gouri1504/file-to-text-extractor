# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (local Mongo or Atlas)
MONGO_URI=mongodb://localhost:27017/claim-extractor

# JWT - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-string
JWT_EXPIRES_IN=7d

# Cookie security: set to true behind HTTPS in production
COOKIE_SECURE=false

# Frontend origin used by CORS and OAuth post-callback redirect
CLIENT_URL=http://localhost:5173

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-key

# Optional: Groq API key as a fallback when Gemini fails or is rate-limited.
# Get one at https://console.groq.com/keys (free tier available).
# Leave blank to disable the fallback. Default model is Llama 4 Scout
# (multimodal). PDFs are supported on the fallback path by rasterizing
# the first 5 pages to JPEG server-side (Groq has no native PDF support).
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
